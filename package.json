    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "modern-css-reset": "^1.4.0",
    "next": "^14.2.4",
    "next-auth": "^4.24.7",
    "prettier": "^3.2.5",
    "react": "^18",
    "react-dom": "^18",
    "react-simple-maps": "^3.0.0"
  },
  "devDependencies": {
